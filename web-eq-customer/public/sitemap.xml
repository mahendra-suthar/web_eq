<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static sitemap covering the app's fixed public pages.
  Per-business (/business/:id) and per-category (/categories/:id) URLs are dynamic
  and should be emitted by a backend-generated sitemap (Phase 2) so new businesses
  are crawled as they are added.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://app.easequeue.com/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://app.easequeue.com/search</loc>
    <changefreq>daily</changefreq>
    <priority>0.7</priority>
  </url>
</urlset>
